{
  "extends": ["eslint:recommended", "prettier"],
  "plugins": ["prettier"],
  "parser": "@typescript-eslint/parser",
  "env": {
    "es6": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 9,
    "sourceType": "module"
  },
  "rules": {
    "prettier/prettier": "error",
    "no-console": 2
  },
  "overrides": [
    {
      "files": ["**/test/**/*.test.ts"],
      "rules": {
        "prettier/prettier": "error"
      },
      "env": {
        "mocha": true
      }
    }
  ],
  "ignorePatterns": ["./node_modules","./dist/**/*"]
}
