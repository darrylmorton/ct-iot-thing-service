{
  "name": "ct-iot-thing-service",
  "version": "0.0.8",
  "description": "CT IoT Thing Service",
  "main": "dist/src/index.js",
  "author": "Darryl Morton",
  "license": "GNU",
  "scripts": {
    "clean": "rm -rf ./dist",
    "build": "./node_modules/typescript/bin/tsc --build",
    "lint": "eslint . --ext .ts",
    "depcheck": "depcheck",
    "migrate:latest": "NODE_ENV=test npx knex migrate:latest",
    "seed:run": "NODE_ENV=test npx knex seed:run",
    "start": "node dist/src/index.js",
    "dev": "concurrently './node_modules/typescript/bin/tsc --watch' 'NODE_ENV=development nodemon -q dist/src/index.js'",
    "test": "NODE_ENV=test mocha -r ts-node/register --config ./test/mocharc.json ./test/**/*.test.ts"
  },
  "engines": {
    "node": ">=16.15"
  },
  "dependencies": {
    "body-parser": "^1.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "envalid": "^7.3.1",
    "express": "^4.18.1",
    "express-openapi": "^12.0.1",
    "knex": "^2.2.0",
    "openapi-response-validator": "^12.0.0",
    "pino": "^8.3.1",
    "pino-http": "^8.1.1",
    "swagger-ui-express": "^4.5.0"
  },
  "peerDependencies": {
    "pg": "^8.7.3"
  },
  "devDependencies": {
    "@types/chai": "^4.3.3",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/mocha": "^9.1.1",
    "@types/node": "^18.6.1",
    "@types/supertest": "^2.0.12",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/parser": "^5.33.1",
    "chai": "^4.3.6",
    "concurrently": "^7.3.0",
    "depcheck": "^1.4.3",
    "eslint": "^8.22.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "mocha": "^10.0.0",
    "nodemon": "^2.0.19",
    "prettier": "^2.7.1",
    "supertest": "^6.2.4",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.2",
    "uuid": "^8.3.2"
  }
}
